# OTAU App — переменные окружения

# Для бесплатного деплоя на Vercel НИЧЕГО задавать не нужно:
# после деплоя будет ссылка вида https://<имя-проекта>.vercel.app
# (Vercel сам подставляет VERCEL_URL для превью и продакшена.)

# Опционально — только если когда-нибудь подключите свой домен:
# NEXT_PUBLIC_SITE_URL=https://ваш-домен.kz
